  <object class="GtkShortcutsWindow" id="shortcuts_window">
    <property name="child">
      <object class="GtkShortcutsSection">
        <property name="title">shortcuts</property>
        <child>
          <object class="GtkShortcutsGroup">
            <property name="title" translatable="yes" context="General section in the Shortcuts window">General</property>
            <child>
              <object class="GtkShortcutsShortcut">
                <property name="accelerator">&lt;Ctrl&gt;Q</property>
                <property name="action-name">win.close</property>
                <property name="title" translatable="yes" context="In the shortcuts window">Close the application</property>
              </object>
            </child>
            <child>
              <object class="GtkShortcutsShortcut">
                <property name="accelerator">&lt;Ctrl&gt;O</property>
                <property name="action-name">win.recognize-file</property>
                <property name="title" translatable="yes" context="In the shortcuts window">Recognize from a file</property>
              </object>
            </child>
            <child>
              <object class="GtkShortcutsShortcut">
                <property name="accelerator">&lt;Primary&gt;comma</property>
                <property name="action-name">win.show-preferences</property>
                <property name="title" translatable="yes" context="In the shortcuts window">Show preferences</property>
              </object>
            </child>
            <child>
              <object class="GtkShortcutsShortcut">
                <property name="accelerator">&lt;Primary&gt;question</property>
                <property name="action-name">win.display-shortcuts</property>
                <property name="title" translatable="yes" context="In the shortcuts window">Display shortcuts</property>
              </object>
            </child>
            <child>
              <object class="GtkShortcutsShortcut">
                <property name="accelerator">F10</property>
                <property name="action-name">win.show-menu</property>
                <property name="title" translatable="yes" context="win.show-menu">Show menu</property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </property>
    <property name="destroy-with-parent">true</property>
    <property name="focus-visible">false</property>
    <property name="hide-on-close">true</property>
    <property name="modal">true</property>
    <property name="transient-for">main_window</property>
  </object>
</interface>
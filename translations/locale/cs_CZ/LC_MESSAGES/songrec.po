msgid "Delete history"
msgstr "Smazat historii"

#: translations/interface.ui.h:42
msgid "Select a file to recognize"
msgstr "Vyberte soubor k rozpoznání"

#: translations/interface.ui.h:43
msgid "Copy artist and track"
msgstr "Kopírovat umělce a skladbu"

#: translations/interface.ui.h:44
msgid "Copy artist"
msgstr "Kopírovat umělce"

#: translations/interface.ui.h:45
msgid "Copy track name"
msgstr "Kopírovat název skladby"

#: translations/interface.ui.h:46
msgid "Copy album"
msgstr "Kopírovat album"

#: translations/interface.ui.h:47
msgid "Delete from History"
msgstr "Odstranit z historie"

#: translations/interface.ui.h:48
msgid "Add to Favorites"
msgstr "Přidat do oblíbených"

#: translations/interface.ui.h:49
msgid "Remove from Favorites"
msgstr "Odstranit z oblíbených"

